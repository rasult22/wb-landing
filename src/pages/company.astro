---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Реквизиты — SellerBox" description="Юридическая информация и банковские реквизиты ТОО «Logic Layer».">
  <Header />
  <main class="pt-28 pb-16">
    <div class="boring-page">
      <a href={`${base}about`} class="back-link">&larr; Назад</a>

      <h1>Реквизиты</h1>

      <table>
        <tbody>
          <tr>
            <td class="label">Наименование</td>
            <td>ТОО «Logic Layer»</td>
          </tr>
          <tr>
            <td class="label">БИН</td>
            <td>250940004392</td>
          </tr>
          <tr>
            <td class="label">Юридический адрес</td>
            <td>Казахстан, г. Алматы, Алмалинский район, ул. Брусиловского, д. 167, кв. 777, 050000</td>
          </tr>
        </tbody>
      </table>

      <h2>Банковские реквизиты</h2>

      <table>
        <tbody>
          <tr>
            <td class="label">Банк</td>
            <td>АО «Народный Банк Казахстана»</td>
          </tr>
          <tr>
            <td class="label">ИИК (KZT)</td>
            <td>KZ71601A861073051941</td>
          </tr>
          <tr>
            <td class="label">ИИК (USD)</td>
            <td>KZ92601A861073051951</td>
          </tr>
          <tr>
            <td class="label">БИК (SWIFT)</td>
            <td>HSBKKZKX</td>
          </tr>
        </tbody>
      </table>

      <h2>Контакты</h2>

      <table>
        <tbody>
          <tr>
            <td class="label">Telegram-бот</td>
            <td><a href="https://t.me/wb_aihelper_bot" target="_blank" rel="noopener">@wb_aihelper_bot</a></td>
          </tr>
          <tr>
            <td class="label">Адрес</td>
            <td>г. Алматы, Казахстан</td>
          </tr>
        </tbody>
      </table>

      <h2>Платёжный провайдер</h2>
      <p>Обработка онлайн-платежей осуществляется через сервис <a href="https://tiptoppay.kz" target="_blank" rel="noopener">TipTopPay</a>. Подробнее — на странице <a href={`${base}payment`}>«Оплата услуг»</a>.</p>

      <p class="disclaimer">SellerBox не является официальным продуктом или партнёром Wildberries. Мы предоставляем независимые инструменты аналитики для продавцов маркетплейса.</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .boring-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
    font-family: 'Times New Roman', Times, serif;
    color: #333;
    font-size: 14px;
    line-height: 1.5;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: #555;
    text-decoration: underline;
    font-size: 13px;
  }
  .back-link:hover {
    color: #000;
  }

  h1 {
    font-size: 20px;
    font-weight: bold;
    font-family: 'Times New Roman', Times, serif;
    margin-bottom: 1.5rem;
    color: #000;
    border-bottom: 1px solid #999;
    padding-bottom: 0.5rem;
  }

  h2 {
    font-size: 16px;
    font-weight: bold;
    font-family: 'Times New Roman', Times, serif;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #000;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  td {
    border: 1px solid #ccc;
    padding: 6px 10px;
    vertical-align: top;
    font-size: 13px;
  }

  td.label {
    width: 180px;
    background-color: #f5f5f5;
    color: #555;
    font-weight: normal;
    white-space: nowrap;
  }

  p {
    margin-bottom: 0.75rem;
    font-size: 13px;
    color: #444;
  }

  a {
    color: #2563eb;
  }
  a:hover {
    color: #1d4ed8;
  }

  .disclaimer {
    margin-top: 2rem;
    padding: 10px 12px;
    background: #fffbe6;
    border: 1px solid #e5d78c;
    font-size: 12px;
    color: #666;
  }
</style>
